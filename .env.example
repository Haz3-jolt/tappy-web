# Recommended for Vercel persistence: add Vercel Redis / Upstash storage.
# Either pair works; Vercel integrations usually inject one of these pairs.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# APK is embedded in this repo at public/downloads/tappy.apk.
# The site hardcodes /downloads/tappy.apk so no external hosting is needed.
