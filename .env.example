# Required: protects /creator and GET /api/waitlist
ADMIN_SECRET=replace-with-a-long-random-secret

# Recommended for Vercel persistence: add Vercel Redis / Upstash storage.
# Either pair works; Vercel integrations usually inject one of these pairs.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# APK download URL. The repo includes public/downloads/tappy.apk.
# You can also point this at an external release URL.
NEXT_PUBLIC_APK_URL=/downloads/tappy.apk
