# Vercel waitlist storage: connect Redis / Upstash.
# The app accepts any one of these configurations.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

# Optional: protects /api/waitlist/export CSV download.
WAITLIST_EXPORT_SECRET=replace-with-a-long-random-secret

# APK is embedded in this repo at public/downloads/tappy.apk.
# The site hardcodes /downloads/tappy.apk so no external hosting is needed.
